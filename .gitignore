# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# vercel
.vercel

# one-off scripts containing real customer data — never commit these
scripts/import-leads-*.ts

# загруженные файлы задач, аватарки, фото мотивации (хранятся на сервере в volume, не в репо)
/uploads

# typescript
*.tsbuildinfo
next-env.d.ts
