generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LeadStage {
  SCHEDULED_CALL
  CALL_DONE
  SECOND_TOUCH_KP
  SECOND_CALL_DONE
  KP_SENT
  APPROVED
  PAID
  IN_PROGRESS
  POSTPAY
  SUPPORT
}

enum TaskPriority {
  P0
  P1
  P2
  P3
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum NotificationType {
  TASK_ASSIGNED
  CALL_INVITED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  avatarUrl    String?
  motivationPhotoKey String?
  passwordHash String
  role         Role     @default(EMPLOYEE)
  isBlocked    Boolean  @default(false)

  // Гранулярные права сотрудника (для ADMIN игнорируются — админ может всё).
  editTasksSelf   Boolean @default(true)
  viewAccounting  Boolean @default(true)
  viewChannels    Boolean @default(true)
  editCrm         Boolean @default(false)
  editTasksOthers Boolean @default(false)

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt    DateTime @default(now())

  telegramChatId          BigInt?   @unique
  telegramUsername        String?
  telegramMorningSentDate String?
  telegramEveningSentDate String?

  leads          Lead[]
  leadActivity   LeadActivity[]
  tasks          Task[]          @relation("TaskAssignee")
  taskComments   TaskComment[]
  taskAttachments TaskAttachment[]
  transactions   Transaction[]
  projectAccess  ProjectMember[]
  channelSpends  ChannelSpend[]
  calendarEvents CalendarEvent[]
  attendingEvents CalendarEvent[] @relation("EventAttendees")
  taskCompletions TaskCompletion[]
  notifications   Notification[]
}

model Project {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)

  tasks   Task[]
  members ProjectMember[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Lead {
  id          String    @id @default(cuid())
  title       String
  company     String?
  description String?
  contactName String?
  contact     String?
  link        String?
  stage       LeadStage @default(SCHEDULED_CALL)
  prepay      Decimal   @default(0) @db.Decimal(12, 2)
  postpay     Decimal   @default(0) @db.Decimal(12, 2)
  monthlySub  Decimal   @default(0) @db.Decimal(12, 2)
  expenses    Decimal   @default(0) @db.Decimal(12, 2)
  notes       String?
  lost        Boolean   @default(false)
  lostReason  String?
  startDate   DateTime  @default(now())
  order       Int       @default(0)
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  channelId   String?
  channel     TrafficChannel? @relation(fields: [channelId], references: [id])

  activity     LeadActivity[]
  transactions Transaction[]

  @@index([stage])
  @@index([channelId])
}

model TrafficChannel {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  leads  Lead[]
  spends ChannelSpend[]
}

model ChannelSpend {
  id          String         @id @default(cuid())
  channelId   String
  channel     TrafficChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  amount      Decimal        @db.Decimal(12, 2)
  date        DateTime       @default(now())
  note        String?
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([channelId])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  createdAt DateTime @default(now())
}

model TaskBoard {
  id      String       @id @default(cuid())
  name    String
  columns TaskColumn[]
}

model TaskColumn {
  id      String @id @default(cuid())
  boardId String
  board   TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name    String
  order   Int
  tasks   Task[]
}

model Task {
  id             String       @id @default(cuid())
  columnId       String
  column         TaskColumn   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  assigneeId     String?
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  priority       TaskPriority @default(P2)
  isBug          Boolean      @default(false)
  estimateHours  Decimal?     @db.Decimal(6, 1)
  dueDate        DateTime?
  order          Int          @default(0)
  archived       Boolean      @default(false)
  completedAt    DateTime?
  deadlineReminderSentAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  comments    TaskComment[]
  nodes       TaskNode[]
  attachments TaskAttachment[]
  completions TaskCompletion[]

  @@index([projectId])
  @@index([assigneeId])
}

// Отдельный, не зависящий от жизни самой задачи, журнал фактов выполнения.
// Если задачу потом удалят или заархивируют, эта запись остаётся — счётчик
// "выполнено суммарно" не должен теряться. taskId/userId ставятся в NULL
// при удалении задачи/пользователя, а не каскадно удаляются.
model TaskCompletion {
  id          String    @id @default(cuid())
  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  taskTitle   String
  completedAt DateTime  @default(now())

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

model TaskAttachment {
  id           String       @id @default(cuid())
  taskId       String
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  commentId    String?
  comment      TaskComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  size         Int
  storageKey   String
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())

  @@index([taskId])
  @@index([commentId])
}

model TaskComment {
  id            String   @id @default(cuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  text          String
  attachmentUrl String?
  createdAt     DateTime @default(now())

  attachments TaskAttachment[]
}

model TaskNode {
  id        String    @id @default(cuid())
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    TaskNode? @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  TaskNode[] @relation("NodeChildren")
  title     String
  dueDate   DateTime?
  done      Boolean   @default(false)
  x         Float     @default(0)
  y         Float     @default(0)
  createdAt DateTime  @default(now())
}

model Kpi {
  id        String   @id @default(cuid())
  metricKey String   @unique
  target    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Токен привязки Telegram-аккаунта — в БД, а не в памяти процесса: переживает
// рестарт/редеплой приложения между "нажал Подключить" и "написал боту /start".
model TelegramLinkToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Settings {
  id                     String @id @default("singleton")
  morningSummaryTime     String @default("09:00")
  eveningSummaryTime     String @default("19:00")
  deadlineCheckInterval  Int    @default(60)
  timezone               String @default("Europe/Moscow")
}

model TransactionCategory {
  id          String            @id @default(cuid())
  name        String
  type        TransactionType
  isRecurring Boolean           @default(false)
  transactions Transaction[]
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  attendees User[] @relation("EventAttendees")

  @@index([startAt])
}

model Transaction {
  id          String               @id @default(cuid())
  categoryId  String
  category    TransactionCategory  @relation(fields: [categoryId], references: [id])
  leadId      String?
  lead        Lead?                @relation(fields: [leadId], references: [id])
  amount      Decimal              @db.Decimal(12, 2)
  type        TransactionType
  description String?
  date        DateTime             @default(now())
  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())
}
